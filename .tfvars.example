# -----------------------------------------------
# Proxmox (lab + core-infra environments)
# -----------------------------------------------
pm_api_url          = "https://<proxmox-host>:8006/api2/json"
pm_api_token_id     = "<user>@pam!<token-name>"
pm_api_token_secret = "<token-secret>"

# SSH key pair used to access provisioned VMs
infra_public_key  = "<contents of id_ed25519_infra.pub>"
infra_private_key = "<contents of id_ed25519_infra>"

# GitHub deploy key (used by Ansible to pull from private repos)
git_private_key = "<contents of id_ed25519_github>"

# Ansible SSH user on provisioned VMs
ansible_user = "<vm-username>"

# -----------------------------------------------
# AWS environment
# -----------------------------------------------
# Passed via environment variables in CI:
# AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY

# CIDR allowed to SSH into the EC2 instance
allowed_ssh_cidr = "<your-ip>/32"

# -----------------------------------------------
# Application (passed as GitHub Actions secrets)
# -----------------------------------------------
# POSTGRES_PASSWORD
# GRAFANA_ADMIN_USER
# GRAFANA_ADMIN_PASSWORD
# APP_DOMAIN